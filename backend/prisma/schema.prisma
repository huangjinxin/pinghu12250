model ReadingLog {
  id                      String                    @id @default(uuid())
  userId                  String
  bookId                  String
  chapterInfo             String?
  readPages               Int                       @default(0)
  content                 String
  likesCount              Int                       @default(0)
  dislikesCount           Int                       @default(0)
  isPublic                Boolean                   @default(true)
  dynamicId               String?                   @unique
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime @updatedAt
  Book                    Book                      @relation(fields: [bookId], references: [id], onDelete: Cascade)
  Dynamic                 Dynamic?                  @relation(fields: [dynamicId], references: [id])
  user                    User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  ReadingLogLike          ReadingLogLike[]
  content_tags_deprecated content_tags_deprecated[]

  @@index([bookId])
  @@index([createdAt])
  @@index([isPublic])
  @@index([userId])
}

model ReadingLogLike {
  id           String     @id @default(uuid())
  readingLogId String
  userId       String
  isLike       Boolean
  createdAt    DateTime   @default(now())
  readingLog   ReadingLog @relation(fields: [readingLogId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([readingLogId, userId])
  @@index([readingLogId])
  @@index([userId])
}

model ReadingNote {
  id                String             @id @default(uuid())
  userId            String
  textbookId        String
  sessionId         String
  sourceType        String
  query             String
  content           Json
  snippet           String
  page              Int
  chapterId         String?
  paragraphId       String?
  textRange         Json?
  isFavorite        Boolean            @default(false)
  favoriteAt        DateTime?
  createdAt         DateTime           @default(now())
  WritingEvaluation WritingEvaluation?

  @@index([createdAt])
  @@index([sessionId])
  @@index([textbookId, chapterId])
  @@index([userId, isFavorite])
  @@index([userId, textbookId])
}

model ReviewSession {
  id                                  String      @id @default(uuid())
  fromUserId                          String
  toUserId                            String
  reviewId                            String?
  action                              String
  createdAt                           DateTime    @default(now())
  fromUser User        @relation("ReviewSession_fromUserIdToUser", fields: [fromUserId], references: [id], onDelete: Cascade)
  PeerReview                          PeerReview? @relation(fields: [reviewId], references: [id])
  toUser   User        @relation("ReviewSession_toUserIdToUser", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([fromUserId])
  @@index([toUserId])
}

model RuleStandard {
  id           String         @id @default(uuid())
  name         String         @unique
  description  String?
  isEnabled    Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  RuleTemplate RuleTemplate[]

  @@index([isEnabled])
}

model RuleSubmission {
  id                                   String             @id @default(uuid())
  userId                               String
  templateId                           String
  content                              String
  images                               String[]
  link                                 String?
  status                               String             @default("PENDING")
  reviewNote                           String?
  reviewedBy                           String?
  reviewedAt                           DateTime?
  pointsAwarded                        Int?
  createdAt                            DateTime           @default(now())
  updatedAt                            DateTime           @updatedAt
  audios                               String[]           @default([])
  quantity                             Int                @default(1)
  AiAutomationTask                     AiAutomationTask[]
  reviewer User?              @relation("RuleSubmission_reviewedByToUser", fields: [reviewedBy], references: [id])
  template                         RuleTemplate       @relation(fields: [templateId], references: [id], onDelete: Cascade)
  user     User               @relation("RuleSubmission_userIdToUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([reviewedBy])
  @@index([status])
  @@index([templateId])
  @@index([userId])
}

model RuleTemplate {
  id               String             @id @default(uuid())
  name             String
  typeId           String
  standardId       String
  requireImage     Boolean            @default(false)
  requireText      Boolean            @default(true)
  requireLink      Boolean            @default(false)
  textMaxLength    Int                @default(500)
  points           Int
  status           String             @default("ENABLED")
  createdBy        String
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  allowQuantity    Boolean            @default(false)
  audioUrl         String?
  description      String?
  requireAudio     Boolean            @default(false)
  action           String?
  dailyLimit       Int?               @default(0)
  submissions      RuleSubmission[]
  author             User               @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  RuleStandard     RuleStandard       @relation(fields: [standardId], references: [id], onDelete: Cascade)
  type         RuleType           @relation(fields: [typeId], references: [id], onDelete: Cascade)
  TemplateFavorite TemplateFavorite[]

  @@index([createdBy])
  @@index([standardId])
  @@index([status])
  @@index([typeId])
}

model RuleType {
  id           String         @id @default(uuid())
  name         String         @unique
  description  String?
  isEnabled    Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  templates RuleTemplate[]

  @@index([isEnabled])
}

model ScanLog {
  id        String   @id @default(uuid())
  userId    String
  scanType  String
  target    String
  params    Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([userId])
}

model School {
  id        String    @id @default(uuid())
  name      String    @unique
  address   String?
  phone     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime @updatedAt
  Class     Class[]
  Teacher   Teacher[]
  User      User[]
}

model Student {
  id            String          @id @default(uuid())
  userId        String          @unique
  classId       String?
  studentNumber String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime @updatedAt
  class         Class?          @relation(fields: [classId], references: [id])
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  StudentParent StudentParent[]

  @@index([classId])
  @@index([userId])
}

model StudentParent {
  id                                String   @id @default(uuid())
  studentId                         String
  parentId                          String
  childId                           String
  createdAt                         DateTime @default(now())
  child  User     @relation("StudentParent_childIdToUser", fields: [childId], references: [id], onDelete: Cascade)
  parent User     @relation("StudentParent_parentIdToUser", fields: [parentId], references: [id], onDelete: Cascade)
  Student                           Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, parentId])
  @@index([parentId])
  @@index([studentId])
}

model SyncConflict {
  id            String    @id @default(uuid())
  userId        String
  entityType    String
  entityId      String
  localVersion  Int
  serverVersion Int
  localData     Json
  serverData    Json
  resolution    String?
  resolvedAt    DateTime?
  createdAt     DateTime  @default(now())

  @@index([createdAt])
  @@index([entityType, entityId])
  @@index([userId, resolution])
}

model SyncDevice {
  id         String   @id @default(uuid())
  userId     String
  deviceId   String   @unique
  deviceName String
  deviceType String
  lastSyncAt DateTime @default(now())
  pushToken  String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([lastSyncAt])
  @@index([userId])
}

model SystemPrompt {
  id          String   @id @default(uuid())
  promptText  String
  description String?
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdBy])
}

model SystemSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  type        String   @default("string")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key])
}

model Task {
  id             String           @id @default(uuid())
  creatorId      String
  title          String
  description    String
  dueDate        DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime @updatedAt
  User           User             @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  TaskSubmission TaskSubmission[]

  @@index([creatorId])
  @@index([dueDate])
}

model TaskSubmission {
  id          String     @id @default(uuid())
  taskId      String
  studentId   String
  status      TaskStatus @default(PENDING)
  content     String?
  attachments String[]
  note        String?
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime @updatedAt
  User        User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  Task        Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, studentId])
  @@index([status])
  @@index([studentId])
}

model Teacher {
  id           String         @id @default(uuid())
  userId       String         @unique
  schoolId     String
  subject      String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime @updatedAt
  school       School         @relation(fields: [schoolId], references: [id])
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  TeacherClass TeacherClass[]

  @@index([schoolId])
  @@index([userId])
}

model TeacherClass {
  id        String   @id @default(uuid())
  teacherId String
  classId   String
  role      String?
  createdAt DateTime @default(now())
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacher   Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, classId])
  @@index([classId])
  @@index([teacherId])
}

model TemplateFavorite {
  id           String       @id @default(uuid())
  userId       String
  templateId   String
  createdAt    DateTime     @default(now())
  template RuleTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, templateId])
  @@index([templateId])
  @@index([userId])
}

model Textbook {
  id               String             @id @default(uuid())
  subject          String
  grade            Int
  semester         String
  version          String             @default("人教版")
  title            String
  totalPages       Int?
  pdfUrl           String?
  coverImage       String?
  contentType      String             @default("pdf")
  epubUrl          String?
  epubMetadata     Json?
  status           String             @default("draft")
  isHidden         Boolean            @default(false)
  createdBy        String
  createdAt        DateTime           @default(now())
  updatedAt        DateTime @updatedAt
  TextbookFavorite TextbookFavorite[]
  TextbookPrompt   TextbookPrompt[]
  TextbookUnit     TextbookUnit[]

  @@unique([subject, grade, semester, version])
  @@index([createdBy])
  @@index([grade])
  @@index([isHidden])
  @@index([status])
  @@index([subject])
}

model TextbookChatMessage {
  id         String   @id @default(uuid())
  userId     String
  textbookId String
  role       String
  content    String
  page       Int?
  sourceType String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([userId, textbookId])
}

model TextbookFavorite {
  id         String   @id @default(uuid())
  userId     String
  textbookId String
  createdAt  DateTime @default(now())
  textbook   Textbook @relation(fields: [textbookId], references: [id], onDelete: Cascade)

  @@unique([userId, textbookId])
  @@index([textbookId])
  @@index([userId])
}

model TextbookLesson {
  id           String               @id @default(uuid())
  unitId       String
  lessonNumber Int
  title        String
  pageStart    Int?
  pageEnd      Int?
  htmlContent  String?
  status       TextbookLessonStatus @default(EMPTY)
  inputBy      String?
  reviewedBy   String?
  reviewNote   String?
  reviewedAt   DateTime?
  sortOrder    Int                  @default(0)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime @updatedAt
  unit TextbookUnit         @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([unitId, lessonNumber])
  @@index([inputBy])
  @@index([sortOrder])
  @@index([status])
  @@index([unitId])
}

model TextbookPrompt {
  id          String   @id @default(uuid())
  textbookId  String
  name        String
  promptText  String
  description String?
  isActive    Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  textbook    Textbook @relation(fields: [textbookId], references: [id], onDelete: Cascade)

  @@index([createdBy])
  @@index([isActive])
  @@index([sortOrder])
  @@index([textbookId])
}

model TextbookUnit {
  id             String           @id @default(uuid())
  textbookId     String
  unitNumber     Int
  title          String
  theme          String?
  pageStart      Int?
  pageEnd        Int?
  sortOrder      Int              @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime @updatedAt
  lessons TextbookLesson[]
  textbook       Textbook         @relation(fields: [textbookId], references: [id], onDelete: Cascade)

  @@unique([textbookId, unitNumber])
  @@index([sortOrder])
  @@index([textbookId])
}

model Transaction {
  id                                String          @id @default(uuid())
  userId                            String
  type                              TransactionType
  amount                            Int
  balance                           Int
  fromUserId                        String?
  toUserId                          String?
  relatedType                       String?
  relatedId                         String?
  description                       String
  metadata                          Json?
  createdAt                         DateTime        @default(now())
  fromUser User?           @relation("Transaction_fromUserIdToUser", fields: [fromUserId], references: [id])
  toUser   User?           @relation("Transaction_toUserIdToUser", fields: [toUserId], references: [id])
  user     User            @relation("Transaction_userIdToUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([relatedType, relatedId])
  @@index([type])
  @@index([userId, createdAt])
}

model TypingPractice {
  id             String   @id @default(uuid())
  authorId       String
  mode           String   @default("interstellar")
  title          String
  score          Int      @default(0)
  totalKeys      Int      @default(0)
  correctKeys    Int      @default(0)
  accuracy       Float    @default(0)
  duration       Int      @default(0)
  wordsDestroyed Int      @default(0)
  maxCombo       Int      @default(0)
  wpm            Int      @default(0)
  isValid        Boolean  @default(false)
  extraData      Json?
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId, createdAt])
  @@index([authorId])
  @@index([createdAt])
  @@index([isValid])
  @@index([mode])
}

model User {
  id                                             String                  @id @default(uuid())
  email                                          String                  @unique
  username                                       String                  @unique
  password                                       String
  role                                           Role                    @default(STUDENT)
  status                                         UserStatus              @default(ACTIVE)
  avatar                                         String?
  createdAt                                      DateTime                @default(now())
  updatedAt                                      DateTime @updatedAt
  schoolId                                       String?
  classId                                        String?
  totalPoints                                    Int                     @default(0)
  lastLoginDate                                  DateTime?
  passwordChangedAt                              DateTime?
  loginStreakDays                                Int                     @default(0)
  followersCount                                 Int                     @default(0)
  followingCount                                 Int                     @default(0)
  friendsCount                                   Int                     @default(0)
  approvedAt                                     DateTime?
  approvedBy                                     String?
  autoAcceptFriend                               Boolean                 @default(false)
  birthDate                                      DateTime?
  deviceToken                                    String?
  friendRequestMessage                           String?
  inviteCodeId                                   Int?
  needsReview                                    Boolean                 @default(true)
  paymentPassword                                String?
  realName                                       String?
  registeredAt                                   DateTime                @default(now())
  studentNumber                                  String?
  twoFactorBackupCodes                           String[]
  twoFactorEnabled                               Boolean                 @default(false)
  twoFactorEnabledAt                             DateTime?
  twoFactorSecret                                String?
  schoolClassUpdatedAt                           DateTime?
  ActiveTimer                                    ActiveTimer[]
  ActivityLog                                    ActivityLog[]
  Answer                                         Answer[]
  BehaviorLog                                    BehaviorLog[]
  Book                                           Book[]
  BotConversation                                BotConversation[]
  BotMessage                                     BotMessage[]
  CalendarEvent                                  CalendarEvent[]
  CalligraphyWork                                CalligraphyWork[]
  Comment                                        Comment[]
  ContentPurchase                                ContentPurchase[]
  CreativeWork                                   CreativeWork[]
  DailyCompletionReward                          DailyCompletionReward[]
  DailyPointsLimit                               DailyPointsLimit[]
  DailyReviewTask                                DailyReviewTask[]
  Diary                                          Diary[]
  DiaryAnalysis                                  DiaryAnalysis[]
  DiaryMakeupCard                                DiaryMakeupCard[]
  DiaryStats                                     DiaryStats?
  DiaryTemplate                                  DiaryTemplate[]
  Dynamic                                        Dynamic[]
  Feedback                                       Feedback[]
  FriendRequest_FriendRequest_fromUserIdToUser   FriendRequest[]         @relation("FriendRequest_fromUserIdToUser")
  FriendRequest_FriendRequest_toUserIdToUser     FriendRequest[]         @relation("FriendRequest_toUserIdToUser")
  Friendship_Friendship_userId1ToUser            Friendship[]            @relation("Friendship_userId1ToUser")
  Friendship_Friendship_userId2ToUser            Friendship[]            @relation("Friendship_userId2ToUser")
  Game                                           Game[]
  GameLongReview                                 GameLongReview[]
  GameLongReviewLike                             GameLongReviewLike[]
  GameReviewComment                              GameReviewComment[]
  GameShortReview                                GameShortReview[]
  HTMLWork                                       HTMLWork[]
  Homework                                       Homework[]
  ImessageSenderMapping                          ImessageSenderMapping[]
  createdInviteCodes          InviteCode[]            @relation("InviteCode_createdByToUser")
  LearningProject                                LearningProject[]
  LearningSession                                LearningSession[]
  LearningSessionLike                            LearningSessionLike[]
  Like                                           Like[]
  LoginActivity                                  LoginActivity[]
  Message_Message_fromUserIdToUser               Message[]               @relation("Message_fromUserIdToUser")
  Message_Message_toUserIdToUser                 Message[]               @relation("Message_toUserIdToUser")
  Movie                                          Movie[]
  MovieLog                                       MovieLog[]
  MovieLogLike                                   MovieLogLike[]
  Music                                          Music[]
  MusicLog                                       MusicLog[]
  MusicLogLike                                   MusicLogLike[]
  Note                                           Note[]
  OfflineActivity                                OfflineActivity[]
  PaidContent                                    PaidContent[]
  PayOrder                                       PayOrder[]
  PaymentPlan                                    PaymentPlan[]
  PeerReview_PeerReview_fromUserIdToUser         PeerReview[]            @relation("PeerReview_fromUserIdToUser")
  PeerReview_PeerReview_toUserIdToUser           PeerReview[]            @relation("PeerReview_toUserIdToUser")
  PinyinPractice                                 PinyinPractice[]
  PoetryWork                                     PoetryWork[]
  PointLog                                       PointLog[]
  profile                                        Profile?
  Question                                       Question[]
  ReadingLog                                     ReadingLog[]
  ReadingLogLike                                 ReadingLogLike[]
  ReviewSession_ReviewSession_fromUserIdToUser   ReviewSession[]         @relation("ReviewSession_fromUserIdToUser")
  ReviewSession_ReviewSession_toUserIdToUser     ReviewSession[]         @relation("ReviewSession_toUserIdToUser")
  RuleSubmission_RuleSubmission_reviewedByToUser RuleSubmission[]        @relation("RuleSubmission_reviewedByToUser")
  RuleSubmission_RuleSubmission_userIdToUser     RuleSubmission[]        @relation("RuleSubmission_userIdToUser")
  RuleTemplate                                   RuleTemplate[]
  ScanLog                                        ScanLog[]
  Student                                        Student?
  StudentParent_StudentParent_childIdToUser      StudentParent[]         @relation("StudentParent_childIdToUser")
  StudentParent_StudentParent_parentIdToUser     StudentParent[]         @relation("StudentParent_parentIdToUser")
  SyncDevice                                     SyncDevice[]
  Task                                           Task[]
  TaskSubmission                                 TaskSubmission[]
  Teacher                                        Teacher?
  TemplateFavorite                               TemplateFavorite[]
  Transaction_Transaction_fromUserIdToUser       Transaction[]           @relation("Transaction_fromUserIdToUser")
  Transaction_Transaction_toUserIdToUser         Transaction[]           @relation("Transaction_toUserIdToUser")
  Transaction_Transaction_userIdToUser           Transaction[]           @relation("Transaction_userIdToUser")
  TypingPractice                                 TypingPractice[]
  approvedByUser                                           User?                   @relation("UserToUser", fields: [approvedBy], references: [id])
  approvedUsers                                     User[]                  @relation("UserToUser")
  class                                          Class?                  @relation(fields: [classId], references: [id])
  inviteCode       InviteCode?             @relation("User_inviteCodeIdToInviteCode", fields: [inviteCodeId], references: [id])
  school                                         School?                 @relation(fields: [schoolId], references: [id])
  UserBookshelf                                  UserBookshelf[]
  UserCreditHistory                              UserCreditHistory[]
  UserCreditProfile                              UserCreditProfile?
  UserDiaryAchievement                           UserDiaryAchievement[]
  UserDiaryPrompt                                UserDiaryPrompt?
  UserEvent                                      UserEvent[]
  UserFollow_UserFollow_followerIdToUser         UserFollow[]            @relation("UserFollow_followerIdToUser")
  UserFollow_UserFollow_followingIdToUser        UserFollow[]            @relation("UserFollow_followingIdToUser")
  UserFont                                       UserFont[]
  UserGameRecord                                 UserGameRecord[]
  UserMovieLibrary                               UserMovieLibrary[]
  UserMusicLibrary                               UserMusicLibrary[]
  UserPoints                                     UserPoints?
  Wallet                                         Wallet?

  @@index([classId])
  @@index([email])
  @@index([schoolId])
  @@index([status])
  @@index([username])
}

model UserAchievement {
  id            String      @id @default(uuid())
  userId        String
  achievementId String
  unlockedAt    DateTime    @default(now())
  isShowcased   Boolean     @default(false)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([achievementId])
  @@index([isShowcased])
  @@index([unlockedAt])
  @@index([userId])
}

model UserBookshelf {
  id             String        @id @default(uuid())
  userId         String
  bookId         String
  status         ReadingStatus @default(WANT_TO_READ)
  totalReadPages Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime @updatedAt
  book           Book          @relation(fields: [bookId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([bookId])
  @@index([status])
  @@index([userId])
}

model UserChallengeRecord {
  id               String              @id @default(uuid())
  userId           String
  dailyChallengeId String
  challengeId      String
  difficulty       ChallengeDifficulty
  status           UserChallengeStatus @default(IN_PROGRESS)
  progress         Int                 @default(0)
  target           Int
  rewardClaimed    Boolean             @default(false)
  completedAt      DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime @updatedAt
  dailyChallenge   DailyChallenge      @relation(fields: [dailyChallengeId], references: [id], onDelete: Cascade)

  @@unique([userId, dailyChallengeId, difficulty])
  @@index([dailyChallengeId])
  @@index([rewardClaimed])
  @@index([status])
  @@index([userId])
}

model UserCreditHistory {
  id                String   @id @default(uuid())
  userId            String
  year              Int
  week              Int
  moralityScore     Float    @default(0)
  intelligenceScore Float    @default(0)
  physiqueScore     Float    @default(0)
  aestheticsScore   Float    @default(0)
  laborScore        Float    @default(0)
  societyScore      Float    @default(0)
  totalScore        Float    @default(0)
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year, week])
  @@index([userId])
}

model UserCreditProfile {
  id                String   @id @default(uuid())
  userId            String   @unique
  moralityScore     Float    @default(0)
  intelligenceScore Float    @default(0)
  physiqueScore     Float    @default(0)
  aestheticsScore   Float    @default(0)
  laborScore        Float    @default(0)
  societyScore      Float    @default(0)
  totalScore        Float    @default(0)
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserDiaryAchievement {
  id               String           @id @default(uuid())
  userId           String
  achievementId    String
  unlockedAt       DateTime         @default(now())
  triggerDiaryId   String?
  achievement DiaryAchievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([achievementId])
  @@index([unlockedAt])
  @@index([userId])
}

model UserDiaryPrompt {
  id           String   @id @default(uuid())
  userId       String   @unique
  singlePrompt String?
  batchPrompt  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserEvent {
  id        String   @id @default(uuid())
  userId    String?
  sessionId String
  eventType String
  eventName String
  page      String?
  metadata  Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([eventName])
  @@index([eventType])
  @@index([userId])
}

model UserFollow {
  id                                String   @id @default(uuid())
  followerId                        String
  followingId                       String
  createdAt                         DateTime @default(now())
  follower  User     @relation("UserFollow_followerIdToUser", fields: [followerId], references: [id], onDelete: Cascade)
  following User     @relation("UserFollow_followingIdToUser", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([createdAt])
  @@index([followerId])
  @@index([followingId])
}

model UserFollowedTag {
  id        String    @id @default(uuid())
  userId    String
  tagId     String
  createdAt DateTime  @default(now())
  tag GlobalTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([userId, tagId])
  @@index([tagId])
  @@index([userId])
}

model UserFont {
  id        String   @id @default(uuid())
  userId    String
  name      String
  fileName  String
  filePath  String
  fileSize  Int
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isDefault])
}

model UserGameRecord {
  id            String         @id @default(uuid())
  userId        String
  gameId        String
  status        GamePlayStatus @default(WANT_TO_PLAY)
  totalPlayTime Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime @updatedAt
  game          Game           @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@index([gameId])
  @@index([status])
  @@index([userId])
}

model UserMovieLibrary {
  id         String         @id @default(uuid())
  userId     String
  movieId    String
  status     WatchingStatus @default(WANT_TO_WATCH)
  watchCount Int            @default(0)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime @updatedAt
  movie      Movie          @relation(fields: [movieId], references: [id], onDelete: Cascade)
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
  @@index([movieId])
  @@index([status])
  @@index([userId])
}

model UserMusicLibrary {
  id        String          @id @default(uuid())
  userId    String
  musicId   String
  status    ListeningStatus @default(WANT_TO_LISTEN)
  playCount Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime @updatedAt
  music     Music           @relation(fields: [musicId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, musicId])
  @@index([musicId])
  @@index([status])
  @@index([userId])
}

model UserPoints {
  id          String   @id @default(uuid())
  userId      String   @unique
  totalPoints Int      @default(0)
  todayPoints Int      @default(0)
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Wallet {
  id                String              @id @default(uuid())
  userId            String              @unique
  balance           Decimal             @default(0) @db.Decimal(10, 2)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime @updatedAt
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@index([userId])
}

model WalletTransaction {
  id          String   @id @default(uuid())
  walletId    String
  amount      Decimal  @db.Decimal(10, 2)
  type        String
  description String?
  relatedType String?
  relatedId   String?
  createdAt   DateTime @default(now())
  wallet      Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([type])
  @@index([walletId])
}

model WritingEvaluation {
  id            String      @id @default(uuid())
  noteId        String      @unique
  userId        String
  overallScore  Int
  scoreLevel    String
  dimensions    Json
  suggestions   Json
  encouragement String?
  modelId       String
  promptVersion String      @default("v1.0")
  inputSnapshot Json?
  rawResponse   String?
  createdAt     DateTime    @default(now())
  note   ReadingNote @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([noteId])
  @@index([userId])
}

model content_tags_deprecated {
  id              String          @id @default(uuid())
  tagId           String
  diaryId         String?
  homeworkId      String?
  noteId          String?
  readingLogId    String?
  createdAt       DateTime        @default(now())
  movieLogId      String?
  musicLogId      String?
  Diary           Diary?          @relation(fields: [diaryId], references: [id], onDelete: Cascade)
  Homework        Homework?       @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  MovieLog        MovieLog?       @relation(fields: [movieLogId], references: [id], onDelete: Cascade)
  MusicLog        MusicLog?       @relation(fields: [musicLogId], references: [id], onDelete: Cascade)
  Note            Note?           @relation(fields: [noteId], references: [id], onDelete: Cascade)
  ReadingLog      ReadingLog?     @relation(fields: [readingLogId], references: [id], onDelete: Cascade)
  tags_deprecated tags_deprecated @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@index([tagId])
}

model tags_deprecated {
  id                      String                    @id @default(uuid())
  name                    String                    @unique
  color                   String?
  createdAt               DateTime                  @default(now())
  content_tags_deprecated content_tags_deprecated[]
}

