generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Achievement {
  id                  String                   @id @default(uuid())
  code                String                   @unique
  name                String
  description         String
  icon                String
  rarity              AchievementRarity        @default(COMMON)
  category            AchievementCategory      @default(CREATION)
  conditionType       AchievementConditionType @default(COUNT)
  conditionValue      Int
  rewardPoints        Int                      @default(0)
  rewardCoins         Int                      @default(0)
  isHidden            Boolean                  @default(false)
  sortOrder           Int                      @default(0)
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime @updatedAt
  achievementProgress AchievementProgress[]
  userAchievements     UserAchievement[]

  @@index([category])
  @@index([code])
  @@index([rarity])
  @@index([sortOrder])
}

model AchievementProgress {
  id            String      @id @default(uuid())
  userId        String
  achievementId String
  currentValue  Int         @default(0)
  targetValue   Int
  updatedAt     DateTime @updatedAt
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([achievementId])
  @@index([userId])
}

model ActiveTimer {
  id              String          @id @default(uuid())
  userId          String
  projectId       String
  startTime       DateTime        @default(now())
  mode            TimerMode       @default(FREE)
  pomodoroCount   Int             @default(0)
  createdAt       DateTime        @default(now())
  LearningProject LearningProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([userId])
}

model ActivityLog {
  id          String   @id @default(uuid())
  userId      String
  action      String
  targetType  String?
  targetId    String?
  description String?
  ipAddress   String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([action])
  @@index([createdAt])
  @@index([userId])
}

model AiAnalysisLog {
  id               String            @id @default(uuid())
  userId           String
  textbookId       String
  sessionId        String
  apiConfigId      String?
  promptId         String?
  inputPages       String
  inputText        String
  fullPrompt       String
  outputText       String?
  tokensUsed       Int?
  responseTime     Int?
  status           String            @default("pending")
  errorMessage     String?
  createdAt        DateTime          @default(now())
  AiApiConfig      AiApiConfig?      @relation(fields: [apiConfigId], references: [id])
  AiPromptTemplate AiPromptTemplate? @relation(fields: [promptId], references: [id])

  @@index([apiConfigId])
  @@index([createdAt])
  @@index([sessionId])
  @@index([status])
  @@index([textbookId])
  @@index([userId])
}

model AiApiConfig {
  id                  String             @id @default(uuid())
  name                String
  baseUrl             String
  apiKey              String?
  model               String             @default("default")
  temperature         Float              @default(0.7)
  maxTokens           Int                @default(2000)
  isEnabled           Boolean            @default(true)
  isDefault           Boolean            @default(false)
  createdBy           String
  createdAt           DateTime           @default(now())
  updatedAt           DateTime @updatedAt
  configType          String             @default("llm")
  embeddingDimension  Int?
  enablePsychologyRAG Boolean            @default(false)
  llmModel            String?
  embeddingModel      String?
  AiAnalysisLog       AiAnalysisLog[]
  AiAutomationTask    AiAutomationTask[]

  @@index([configType])
  @@index([createdBy])
  @@index([isEnabled, isDefault])
}

model AiAutomationTask {
  id                String           @id @default(uuid())
  taskType          String
  sourceType        String
  sourceId          String
  triggerMode       String           @default("auto")
  status            String           @default("pending")
  retryCount        Int              @default(0)
  errorMessage      String?
  payload           Json?
  resultSummary     Json?
  processedAt       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime @updatedAt
  aiConfigId        String?
  submissionId      String?
  calligraphyWorkId String?
  AiApiConfig       AiApiConfig?     @relation(fields: [aiConfigId], references: [id])
  CalligraphyWork   CalligraphyWork? @relation(fields: [calligraphyWorkId], references: [id])
  RuleSubmission    RuleSubmission?  @relation(fields: [submissionId], references: [id])

  @@index([calligraphyWorkId])
  @@index([sourceType, sourceId])
  @@index([status, createdAt])
  @@index([submissionId])
  @@index([taskType, status])
}

model AiPrompt {
  id        String   @id @default(uuid())
  key       String   @unique
  name      String
  content   String
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model AiPromptTemplate {
  id            String          @id @default(uuid())
  name          String
  subject       String?
  promptText    String
  description   String?
  isDefault     Boolean         @default(false)
  isEnabled     Boolean         @default(true)
  createdBy     String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime @updatedAt
  AiAnalysisLog AiAnalysisLog[]

  @@index([createdBy])
  @@index([isEnabled])
  @@index([subject, isDefault])
}

model Answer {
  id         String       @id @default(uuid())
  questionId String
  userId     String
  content    String
  createdAt  DateTime     @default(now())
  updatedAt  DateTime @updatedAt
  isBest     Boolean      @default(false)
  likesCount Int          @default(0)
  question   Question     @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  AnswerLike AnswerLike[]

  @@index([createdAt])
  @@index([questionId])
  @@index([userId])
}

model AnswerLike {
  id        String   @id @default(uuid())
  answerId  String
  userId    String
  createdAt DateTime @default(now())
  Answer    Answer   @relation(fields: [answerId], references: [id], onDelete: Cascade)

  @@unique([answerId, userId])
  @@index([answerId])
  @@index([userId])
}

model BehaviorLog {
  id           String         @id @default(uuid())
  userId       String
  behaviorType BehaviorType
  action       String
  duration     Int?
  description  String?
  sourceId     String?
  createdAt    DateTime       @default(now())
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  CreditImpact CreditImpact[]

  @@index([action])
  @@index([behaviorType])
  @@index([userId])
}

model Book {
  id            String          @id @default(uuid())
  title         String
  author        String?
  coverUrl      String?
  isbn          String?         @unique
  description   String?
  publisher     String?
  publishDate   DateTime?
  totalPages    Int?
  category      String?
  sourceType    String?
  sourceUrl     String?
  createdBy     String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime @updatedAt
  User          User            @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  ReadingLog    ReadingLog[]
  UserBookshelf UserBookshelf[]

  @@index([author])
  @@index([category])
  @@index([createdBy])
  @@index([title])
}

model Bot {
  id              String            @id @default(uuid())
  name            String
  avatar          String?
  description     String?
  type            String
  modules         Json              @default("[]")
  keywords        Json              @default("[]")
  welcome         String?
  isActive        Boolean           @default(true)
  sortOrder       Int               @default(0)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime @updatedAt
  BotConversation BotConversation[]
  BotMessage      BotMessage[]

  @@index([isActive])
  @@index([type])
}

model BotConversation {
  id            String       @id @default(uuid())
  userId        String
  botId         String
  lastMessageAt DateTime     @default(now())
  unreadCount   Int          @default(0)
  createdAt     DateTime     @default(now())
  Bot           Bot          @relation(fields: [botId], references: [id], onDelete: Cascade)
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    BotMessage[]

  @@unique([userId, botId])
  @@index([lastMessageAt])
  @@index([userId])
}

model BotMessage {
  id              String          @id @default(uuid())
  conversationId  String
  botId           String
  userId          String
  senderType      String
  msgType         String          @default("text")
  content         String?
  cardData        Json?
  createdAt       DateTime        @default(now())
  Bot             Bot             @relation(fields: [botId], references: [id], onDelete: Cascade)
  conversation BotConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([userId])
}

model CalendarEvent {
  id          String    @id @default(uuid())
  userId      String
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?
  color       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([startDate])
  @@index([userId])
}

model CalligraphyLike {
  id              String          @id @default(uuid())
  userId          String
  workId          String
  createdAt       DateTime        @default(now())
  CalligraphyWork CalligraphyWork @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@unique([userId, workId])
  @@index([workId])
}

model CalligraphyWork {
  id               String             @id @default(uuid())
  authorId         String
  title            String
  content          Json
  preview          String
  fontId           String?
  charCount        Int
  createdAt        DateTime           @default(now())
  status           CalligraphyStatus  @default(PENDING)
  reviewedAt       DateTime?
  reviewedBy       String?
  reviewNote       String?
  evaluationScore  Int?
  evaluationData   Json?
  evaluatedAt      DateTime?
  evaluatedBy      String?
  previewUrl       String?
  previewThumbUrl  String?
  AiAutomationTask AiAutomationTask[]
  CalligraphyLike  CalligraphyLike[]
  author             User               @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@index([createdAt])
  @@index([status])
}

model Category {
  id           String         @id @default(uuid())
  name         String
  slug         String         @unique
  description  String?
  icon         String?
  points       Int            @default(5)
  sortOrder    Int            @default(0)
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime @updatedAt
  works CreativeWork[]

  @@index([isActive])
  @@index([slug])
  @@index([sortOrder])
}

model ChallengeTemplate {
  id                                                                 String                 @id @default(uuid())
  title                                                              String
  description                                                        String
  type                                                               ChallengeType
  difficulty                                                         ChallengeDifficulty
  conditionType                                                      ChallengeConditionType
  conditionValue                                                     Int
  rewardPoints                                                       Int
  rewardCoins                                                        Int
  isActive                                                           Boolean                @default(true)
  weight                                                             Int                    @default(1)
  createdAt                                                          DateTime               @default(now())
  updatedAt                                                          DateTime @updatedAt
  DailyChallenge_Easy   DailyChallenge[] @relation("DailyChallenge_easyChallenge")
  DailyChallenge_Hard   DailyChallenge[] @relation("DailyChallenge_hardChallenge")
  DailyChallenge_Medium DailyChallenge[] @relation("DailyChallenge_mediumChallenge")

  @@index([difficulty])
  @@index([isActive])
  @@index([type])
}

model Class {
  id           String         @id @default(uuid())
  name         String
  grade        String?
  schoolId     String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime @updatedAt
  school       School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  Student      Student[]
  TeacherClass TeacherClass[]
  User         User[]

  @@unique([schoolId, grade, name])
  @@index([schoolId])
}

model Comment {
  id            String    @id @default(uuid())
  authorId      String
  content       String
  dynamicId     String?
  workId        String?
  parentId      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime @updatedAt
  diaryId       String?
  user          User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  Diary         Diary?    @relation(fields: [diaryId], references: [id], onDelete: Cascade)
  Dynamic       Dynamic?  @relation(fields: [dynamicId], references: [id], onDelete: Cascade)
  Comment       Comment?  @relation("CommentToComment", fields: [parentId], references: [id], onDelete: Cascade)
  other_Comment Comment[] @relation("CommentToComment")
  HTMLWork      HTMLWork? @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@index([diaryId])
  @@index([dynamicId])
  @@index([workId])
}

model ContentPurchase {
  id            String      @id @default(uuid())
  userId        String
  paidContentId String
  price         Int
  createdAt     DateTime    @default(now())
  content   PaidContent @relation(fields: [paidContentId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, paidContentId])
  @@index([createdAt])
  @@index([userId])
}

model ContentTag {
  id          String      @id @default(uuid())
  tagId       String
  contentType ContentType
  contentId   String
  userId      String
  createdAt   DateTime    @default(now())
  GlobalTag   GlobalTag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([tagId, contentType, contentId])
  @@index([contentType, contentId])
  @@index([createdAt])
  @@index([tagId])
  @@index([userId])
}

model Conversation {
  id              String     @id @default(uuid())
  friendshipId    String     @unique
  lastMessageId   String?
  lastMessageTime DateTime?
  user1Unread     Int        @default(0)
  user2Unread     Int        @default(0)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime @updatedAt
  Friendship      Friendship @relation(fields: [friendshipId], references: [id], onDelete: Cascade)
  Message         Message[]

  @@index([lastMessageTime])
}

model CreativeWork {
  id               String             @id @default(uuid())
  authorId         String
  categoryId       String
  title            String
  type             String?
  htmlCode         String
  plainText        String?
  status           CreativeWorkStatus @default(PENDING)
  reviewReason     String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime @updatedAt
  author             User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  Category         Category           @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  CreativeWorkLike CreativeWorkLike[]

  @@index([authorId])
  @@index([categoryId])
  @@index([createdAt])
  @@index([status])
}

model CreativeWorkLike {
  id           String       @id @default(uuid())
  userId       String
  workId       String
  isLike       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  CreativeWork CreativeWork @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@unique([userId, workId])
  @@index([userId])
  @@index([workId])
}

model CreditImpact {
  id          String          @id @default(uuid())
  userId      String
  behaviorId  String
  dimension   CreditDimension
  rawPoints   Float
  finalPoints Float
  createdAt   DateTime        @default(now())
  BehaviorLog BehaviorLog     @relation(fields: [behaviorId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CreditRule {
  id           String          @id @default(uuid())
  behaviorType BehaviorType
  action       String
  dimension    CreditDimension
  points       Float
  conditions   Json?
  isEnabled    Boolean         @default(true)
  description  String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime @updatedAt
  weight       Float           @default(1.0)
}

model DailyActiveStats {
  id          String   @id @default(uuid())
  date        DateTime @unique @db.Date
  dau         Int
  newUsers    Int      @default(0)
  totalEvents Int      @default(0)
  pageViews   Int      @default(0)
  topPages    Json?
  topActions  Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DailyChallenge {
  id                                                                    String                @id @default(uuid())
  challengeDate                                                         String                @unique
  easyChallengeId                                                       String
  mediumChallengeId                                                     String
  hardChallengeId                                                       String
  createdAt                                                             DateTime              @default(now())
  easyChallenge                                                       ChallengeTemplate     @relation("DailyChallenge_easyChallenge", fields: [easyChallengeId], references: [id])
  hardChallenge                                                       ChallengeTemplate     @relation("DailyChallenge_hardChallenge", fields: [hardChallengeId], references: [id])
  mediumChallenge                                                     ChallengeTemplate     @relation("DailyChallenge_mediumChallenge", fields: [mediumChallengeId], references: [id])
  UserChallengeRecord                                                   UserChallengeRecord[]

  @@index([challengeDate])
}

model DailyCompletionReward {
  id           String   @id @default(uuid())
  userId       String
  date         String
  streakDays   Int
  basePoints   Int
  streakPoints Int
  totalPoints  Int
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([date])
  @@index([userId])
}

model DailyPointsLimit {
  id           String   @id @default(uuid())
  userId       String
  date         DateTime @db.Date
  earnedPoints Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([date])
  @@index([userId])
}

model DailyReviewTask {
  id             String   @id @default(uuid())
  userId         String
  date           String
  taskType       String
  status         String   @default("pending")
  targetUserIds  String[]
  completedCount Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, taskType])
  @@index([date])
  @@index([userId])
}

model Diary {
  id                      String                    @id @default(uuid())
  authorId                String
  title                   String
  content                 String
  mood                    String?
  weather                 String?
  dynamicId               String?                   @unique
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime @updatedAt
  isPublic                Boolean                   @default(true)
  checksum                String?
  deletedAt               DateTime?
  deviceId                String?
  duplicateStats          Json?
  isBackfill              Boolean                   @default(false)
  isMadeUp                Boolean                   @default(false)
  localId                 String?                   @unique
  logicalDate             DateTime?
  submittedAt             DateTime?
  syncedAt                DateTime?
  version                 Int                       @default(1)
  wordCount               Int?
  wordLevel               Int                       @default(0)
  wordStats               Json?
  status                  String?                   @default("PENDING") @db.VarChar(20)
  Comment                 Comment[]
  author                    User                      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  Dynamic                 Dynamic?                  @relation(fields: [dynamicId], references: [id])
  DiaryComment            DiaryComment[]
  tags                    content_tags_deprecated[]

  @@index([authorId])
  @@index([authorId, logicalDate])
  @@index([authorId, syncedAt])
  @@index([createdAt])
  @@index([isPublic])
  @@index([version])
}

model DiaryAchievement {
  id                   String                 @id @default(uuid())
  code                 String                 @unique
  name                 String
  description          String
  emoji                String
  category             String
  conditionType        String
  conditionValue       String
  rewardPoints         Int                    @default(0)
  sortOrder            Int                    @default(0)
  isActive             Boolean                @default(true)
  createdAt            DateTime               @default(now())
  UserDiaryAchievement UserDiaryAchievement[]

  @@index([category])
  @@index([code])
  @@index([isActive])
}

model DiaryAnalysis {
  id                 String   @id @default(uuid())
  userId             String
  isBatch            Boolean  @default(false)
  period             String?
  diaryId            String?
  diaryIds           String[]
  diaryCount         Int      @default(1)
  diarySnapshot      Json
  analysis           String
  modelName          String?
  tokensUsed         Int?
  responseTime       Int?
  totalScore         Int?
  grade              String?
  scoreDetails       Json?
  highlights         String[]
  improvements       String[]
  nextGoal           String?
  authorProfile      Json?
  charactersProfile  Json?
  socialStyle        String?
  funSummary         String?
  psychologySummary  Json?
  previousAnalysisId String?
  createdAt          DateTime @default(now())
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([diaryId])
  @@index([isBatch])
  @@index([userId])
}

model DiaryComment {
  id        String   @id @default(uuid())
  diaryId   String
  nickname  String   @default("匿名用户")
  content   String
  createdAt DateTime @default(now())
  Diary     Diary    @relation(fields: [diaryId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([diaryId])
}

model DiaryDefaultPrompt {
  id           String   @id @default(uuid())
  singlePrompt String
  batchPrompt  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model DiaryEmbedding {
  id          String                 @id @default(uuid())
  userId      String
  diaryId     String
  weekId      String
  chunkIndex  Int
  content     String
  contentHash String
  embedding   Unsupported("vector")?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([diaryId, chunkIndex])
  @@index([diaryId])
  @@index([userId])
  @@index([userId, weekId])
  @@index([weekId])
}

model DiaryMakeupCard {
  id             String    @id @default(uuid())
  userId         String
  purchasedAt    DateTime  @default(now())
  purchaseWeek   String
  pointsCost     Int       @default(250)
  usedAt         DateTime?
  usedForDate    DateTime?
  usedForDiaryId String?
  status         String    @default("unused")
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([purchaseWeek])
  @@index([status])
  @@index([userId])
}

model DiaryStats {
  id              String    @id @default(uuid())
  userId          String    @unique
  currentStreak   Int       @default(0)
  maxStreak       Int       @default(0)
  lastDiaryDate   DateTime?
  rank            String    @default("bronze")
  rankUpdatedAt   DateTime?
  totalDiaries    Int       @default(0)
  totalWords      Int       @default(0)
  totalAnalyses   Int       @default(0)
  avgScore        Float?
  weekStartDate   DateTime?
  weeklyDiaries   Int       @default(0)
  weeklyWords     Int       @default(0)
  weeklyBestScore Int?
  weeklyBestGrade String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([currentStreak])
  @@index([rank])
  @@index([userId])
}

model DiaryTemplate {
  id          String   @id @default(uuid())
  authorId    String
  name        String
  icon        String   @default("📝")
  description String?
  title       String   @default("")
  content     String
  isSystem    Boolean  @default(false)
  useCount    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  author        User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@index([createdAt])
  @@index([useCount])
}

model Dynamic {
  id          String      @id @default(uuid())
  authorId    String
  content     String
  images      String[]
  isPublic    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime @updatedAt
  dynamicType String?
  location    String?
  mood        String?
  moodScore   Int?
  photoType   String?
  Comment     Comment[]
  Diary       Diary?
  user        User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  HTMLWork    HTMLWork?
  Homework    Homework?
  Like        Like[]
  MovieLog    MovieLog?
  MusicLog    MusicLog?
  ReadingLog  ReadingLog?

  @@index([authorId])
  @@index([createdAt])
  @@index([dynamicType])
  @@index([isPublic])
}

model EmbeddingTask {
  id          String    @id @default(uuid())
  diaryId     String
  userId      String
  status      String    @default("pending")
  retryCount  Int       @default(0)
  errorMsg    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime @updatedAt
  processedAt DateTime?

