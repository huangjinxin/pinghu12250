model TeacherBinding {
  id         String   @id @default(uuid())
  studentId  String   @db.VarChar(100)
  teacherId  String   @db.VarChar(100)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  status     String   @default("ACTIVE") @db.VarChar(20)
  boundAt    DateTime @default(now())

  @@index([studentId])
  @@index([teacherId])
  @@index([status])
}

model DelegatedReview {
  id             String    @id @default(uuid())
  submissionId   String    @db.VarChar(100)
  teacherId      String    @db.VarChar(100)
  status         String    @default("PENDING") @db.VarChar(20)
  reviewComment  String?   @db.Text
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  reviewedAt     DateTime?

  @@index([submissionId])
  @@index([teacherId])
  @@index([status])
}

model TeacherStats {
  id               String   @id @default(uuid())
  teacherId        String   @unique @db.VarChar(100)
  score            Int      @default(0)
  level            Int      @default(1)
  totalReviews     Int      @default(0)
  correctReviews   Int      @default(0)
  wrongReviews     Int      @default(0)
  consecutiveWrong Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([score(sort: Desc)])
}

model ReviewQualityLog {
  id             String   @id @default(uuid())
  teacherId      String   @db.VarChar(100)
  submissionId   String   @db.VarChar(100)
  teacherAction  String   @db.VarChar(20)
  adminAction    String   @db.VarChar(20)
  isConsistent   Boolean
  pointsDelta    Int
  createdAt      DateTime @default(now())

  @@index([teacherId])
  @@index([submissionId])
}

model UserSession {
  id           String   @id @default(uuid())
  userId       String   @db.VarChar(100)
  tokenHash    String   @unique
  device       String?
  ip           String?
  isRevoked    Boolean  @default(false)
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}
