# @AI:DIR composables
permit: add
naming: use[A-Z][a-zA-Z]+\.js
layer: logic

# 可导入
import:
  - "@/api/*"
  - "@/stores/*"
  - "@/utils/*"
  - "vue"
  - "vue-router"

# 禁止导入
!import:
  - "@/components/*"
  - "@/views/*"

# 导出规范
export: function use*() { return { state, methods } }

