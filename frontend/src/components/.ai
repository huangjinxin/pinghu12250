# @AI:DIR components
permit: add
naming: "[Module][Name].vue"

# 子目录规则
subdirs:
  _shared:   通用组件,可被任意模块引用
  textbook:  教材系统专用,仅textbook视图可用
  chat:      聊天系统专用(已废弃,用textbook/Chat*)

# 可导入
import:
  - "@/composables/*"
  - "@/stores/*"
  - "@/utils/*"
  - "同目录其他组件"

# 禁止导入
!import:
  - "@/api/*"      # 必须通过composable
  - "axios"        # 必须通过composable
  - "fetch"        # 必须通过composable

# 废弃文件(不要修改,不要引用)
deprecated:
  - ChatPanel.vue
  - ChatPanelContent.vue
  - ChatWindow.vue
  - ChatWindowContainer.vue
  - ChatDetail.vue
  - "*.vue.bak"
